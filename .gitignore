# CMake build artifacts
cmake-build-*/
build/
out/
CMakeLists.txt.user
CMakeCache.txt
CMakeFiles
CMakeScripts
Testing
Makefile
cmake_install.cmake
install_manifest.txt
compile_commands.json
CTestTestfile.cmake
_deps
CMakeUserPresets.json

# CLion / JetBrains — project settings (.idea) are shared so VCS mappings,
# run configs etc. work for everyone; only user-specific state is ignored.
# See https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
.idea/workspace.xml
.idea/usage.statistics.xml
.idea/tasks.xml
.idea/shelf/
.idea/dictionaries/

# Other IDEs / editors
.vscode/
*.swp

# macOS
.DS_Store

# Runtime artifacts
*.log
config.json
